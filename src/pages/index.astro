---
import { Image } from 'astro:assets'

import { PostPreview } from 'astro-pure/components/pages'
import { getBlogCollection, getUniqueTags, sortMDByDate } from 'astro-pure/server'
import { Button, Icon, Label } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'
import config from '@/site-config'

const MAX_POSTS = 5
const allPosts = await getBlogCollection()
const allPostsByDate = sortMDByDate(allPosts).slice(0, MAX_POSTS)
const uniqueTags = getUniqueTags(allPosts).slice(0, 10) // Limited to top 10 for better performance

// Featured posts for authority
const featuredPostSlugs = ['idor-tryhackme-write-up', 
'a-practical-guide-to-understanding-and-mitigating-sqli',
'react2shell-cve-2025-55182-tryhackme-write-up',
'n8n-cve-2025-68613-tryhackme-write-up']
const featuredPosts = allPosts.filter(p => featuredPostSlugs.includes(p.id))

const imagePath = config.logo.src
const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/*.{jpeg,jpg,png,gif,avif,webp}'
)
if (!images[imagePath])
  throw new Error(
    `"${imagePath}" does not exist in glob: "src/assets/*.{jpeg,jpg,png,gif,avif,webp}"`
  )
---

<PageLayout 
  meta={{ 
    title: 'Cybersecurity Research & Vulnerability Lab | Farros',
    description: 'Independent research on web vulnerabilities, exploitation techniques, offensive security, and system defense through the lens of data engineering.'
  }} 
  highlightColor='#659EB9'
>
  <main class='flex w-full flex-col items-center'>
    <!-- 1. Authority Header - Tightened Spacing -->
    <section class='animate mb-8 flex flex-col items-center w-full border-b pb-8' id='content-header'>
      <div class='flex flex-col items-center gap-y-4 text-center'>
        <h1 class='text-3xl font-bold tracking-tight sm:text-5xl'>
          Cybersecurity Research & <span class="text-primary">Vulnerability Lab</span>
        </h1>
        <p class='max-w-3xl text-muted-foreground text-lg leading-relaxed'>
          Independent research on web vulnerabilities, exploitation techniques, offensive security, and system defense through the lens of data engineering.
        </p>
        
        <div class='flex flex-wrap justify-center gap-x-7 gap-y-3 mt-1'>
          <Label title='GitHub' as='a' href='https://github.com/farrosfr' target='_blank'>
            <Icon name='github' class='size-5' slot='icon' />
          </Label>
          <Label title='LinkedIn' as='a' href='https://www.linkedin.com/in/farrosfr/' target='_blank'>
            <Icon name='link' class='size-5' slot='icon' />
          </Label>
          <Label title='RSS Feed' as='a' href='/rss.xml'>
            <Icon name='rss' class='size-5' slot='icon' />
          </Label>
        </div>
      </div>
    </section>

    <!-- 2. Main Content -->
    <div id='content' class='animate flex flex-col gap-y-12 w-full'>
      
      <!-- Combined Publication Feed & Sidebar -->
      <div class='grid grid-cols-1 gap-x-12 gap-y-10 lg:grid-cols-[1fr_320px]'>
        
        <!-- Main Column: Research Feed -->
        <section class='flex flex-col gap-y-4'>
          <div class='flex items-center justify-between border-b pb-4'>
            <h2 class='text-2xl font-bold flex items-center'>
              <Icon name='link' class='me-3 size-6 text-primary' />
              Latest Articles
            </h2>
            <a href='/blog' class='text-sm text-muted-foreground hover:text-primary transition-colors'>View Archives →</a>
          </div>
          
          <ul class='flex flex-col gap-y-2'>
            {allPostsByDate.map((post) => (
              <li class='animate'>
                <PostPreview {post} detailed />
              </li>
            ))}
          </ul>
          
          <Button title='View All Publications' class='w-fit self-center mt-4' href='/blog' variant='ahead' />
        </section>

        <!-- Sidebar -->
        <aside class='flex flex-col gap-y-8'>
          <!-- Tags Cloud - Compact Layout -->
          <div class='rounded-2xl border bg-muted/30 p-4'>
            <h2 class='mb-3 flex items-center text-sm font-bold uppercase tracking-widest text-muted-foreground'>
              <Icon name='github' class='me-2 size-4' />
              Top Topics
            </h2>
            <ul class='flex flex-wrap gap-1.5'>
              {uniqueTags.map((tag) => (
                <li>
                  <Button title={tag} href={`/tags/${tag}`} variant='pill' class='text-[11px] bg-background hover:bg-primary hover:text-primary-foreground transition-all' />
                </li>
              ))}
            </ul>
          </div>

          <!-- Featured Quick Links -->
          <div class='flex flex-col gap-y-4 px-2'>
            <h2 class='flex items-center text-sm font-bold uppercase tracking-widest text-muted-foreground'>
              <Icon name='link' class='me-2 size-4 text-yellow-500' />
              Featured Reads
            </h2>
            <div class='flex flex-col gap-y-3'>
              {featuredPosts.map((p) => (
                <a href={`/blog/${p.id}`} class='group flex flex-col gap-y-0.5'>
                  <span class='text-sm font-medium group-hover:text-primary transition-colors line-clamp-2'>{p.data.title}</span>
                  <span class='text-[10px] uppercase tracking-wider text-muted-foreground'>{p.data.publishDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
                </a>
              ))}
            </div>
          </div>

          <!-- About Card -->
          <div class='rounded-2xl border p-5 bg-gradient-to-br from-primary/5 to-transparent text-sm'>
            <h3 class='mb-2 font-bold text-base text-primary'>The Researcher</h3>
            <p class='leading-relaxed text-muted-foreground mb-4'>
              <strong>Mochammad Farros Fatchur Roji</strong> is an independent Security Researcher and professional Data Engineer specializing in offensive security and secure data architecture. 
            </p>
            <div class='flex gap-2'>
              <Button title='Full Profile' href='/about' variant='button' class='flex-1 justify-center text-xs shadow-sm' />
              <Button title='View Projects' href='/projects' variant='button' class='flex-1 justify-center text-xs shadow-sm' />
            </div>
          </div>
        </aside>

      </div>

    </div>
  </main>
</PageLayout>
